# ── Auth bypass (local dev) ───────────────────────────────────────
# Set to "true" to skip session authentication during local development
AUTH_BYPASS=true

# ── Auth credentials ──────────────────────────────────────────────
# Generate the password hash with: npx tsx scripts/hash-password.ts <your-password>
AUTH_EMAIL=your-shared-email@example.com
AUTH_PASSWORD_HASH=$2b$12$...your-bcrypt-hash-here...

# ── Session secret ────────────────────────────────────────────────
# Any random string — used to sign the session cookie
SESSION_SECRET=change-me-to-a-random-string

# ── Server ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
